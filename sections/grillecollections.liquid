{% comment %}
================================================================
  Section "Grille de collections" — page d'accueil
  ▸ Vignettes cliquables avec étiquette (modifiable dans le
    personnalisateur de thème : images, textes, liens, couleurs)
  ▸ PC : 6 colonnes côte à côte
  ▸ Tablette : 3 colonnes
  ▸ Mobile : 2 colonnes

  INSTALLATION :
  1. Admin Shopify > Boutique en ligne > Thèmes > ⋯ > Modifier le code
  2. Dossier "sections" > Ajouter une nouvelle section
  3. Nommer : grille-collections  (type .liquid)
  4. Coller tout ce fichier, enregistrer
  5. Personnaliser le thème > page d'accueil > Ajouter une section
     > "Grille de collections"
================================================================
{% endcomment %}

<style>
  .cgrid-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }
  .cgrid-{{ section.id }} .cgrid__inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 {{ section.settings.side_padding }}px;
  }
  .cgrid-{{ section.id }} .cgrid__heading {
    margin: 0 0 24px;
    font-size: 26px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-align: {{ section.settings.heading_align }};
    color: {{ section.settings.heading_color }};
  }
  .cgrid-{{ section.id }} .cgrid__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    gap: {{ section.settings.gap }}px;
  }
  .cgrid-{{ section.id }} .cgrid__card {
    position: relative;
    display: block;
    overflow: hidden;
    border-radius: {{ section.settings.radius }}px;
    text-decoration: none;
  }
  .cgrid-{{ section.id }} .cgrid__media {
    position: relative;
    width: 100%;
    aspect-ratio: {{ section.settings.ratio }};
    background: #e8e2d6;
  }
  .cgrid-{{ section.id }} .cgrid__media img,
  .cgrid-{{ section.id }} .cgrid__media svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .5s ease;
  }
  .cgrid-{{ section.id }} .cgrid__card:hover .cgrid__media img {
    transform: scale(1.045);
  }
  .cgrid-{{ section.id }} .cgrid__label {
    position: absolute;
    left: 50%;
    bottom: 14px;
    transform: translateX(-50%);
    max-width: calc(100% - 16px);
    padding: 8px 14px;
    background: {{ section.settings.label_bg }};
    color: {{ section.settings.label_color }};
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: background .25s ease;
  }
  .cgrid-{{ section.id }} .cgrid__card:hover .cgrid__label {
    background: {{ section.settings.label_bg_hover }};
  }

  /* ----- Tablette : 3 colonnes pour éviter des vignettes écrasées ----- */
  @media (min-width: 750px) and (max-width: 1099px) {
    .cgrid-{{ section.id }} .cgrid__grid {
      grid-template-columns: repeat({{ section.settings.columns_tablet }}, 1fr);
    }
  }

  /* ----- Mobile : 2 colonnes, étiquette en bandeau pleine largeur ----- */
  @media (max-width: 749px) {
    .cgrid-{{ section.id }} .cgrid__grid {
      grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
      gap: {{ section.settings.gap_mobile }}px;
    }
    .cgrid-{{ section.id }} .cgrid__heading { font-size: 21px; margin-bottom: 16px; }
    .cgrid-{{ section.id }} .cgrid__label {
      left: 0;
      bottom: 0;
      transform: none;
      width: 100%;
      max-width: none;
      text-align: center;
      padding: 10px 6px;
      font-size: 11px;
      white-space: normal;
    }
  }
</style>

<div class="cgrid-{{ section.id }}">
  <div class="cgrid__inner">

    {% if section.settings.heading != blank %}
      <h2 class="cgrid__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="cgrid__grid">
      {% for block in section.blocks %}
        {%- liquid
          assign card_url = block.settings.link
          if card_url == blank and block.settings.collection != blank
            assign card_url = block.settings.collection.url
          endif
        -%}
        <a class="cgrid__card"
           {% if card_url != blank %}href="{{ card_url }}"{% endif %}
           {{ block.shopify_attributes }}>
          <div class="cgrid__media">
            {% if block.settings.image != blank %}
              {{ block.settings.image
                 | image_url: width: 800
                 | image_tag: loading: 'lazy', widths: '300, 400, 600, 800',
                   sizes: '(max-width: 749px) 50vw, (max-width: 1099px) 33vw, 17vw',
                   alt: block.settings.label }}
            {% elsif block.settings.collection.featured_image != blank %}
              {{ block.settings.collection.featured_image
                 | image_url: width: 800
                 | image_tag: loading: 'lazy', widths: '300, 400, 600, 800',
                   sizes: '(max-width: 749px) 50vw, (max-width: 1099px) 33vw, 17vw',
                   alt: block.settings.label }}
            {% else %}
              {{ 'collection-1' | placeholder_svg_tag }}
            {% endif %}
          </div>
          {% if block.settings.label != blank %}
            <span class="cgrid__label">{{ block.settings.label }}</span>
          {% endif %}
        </a>
      {% endfor %}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Grille de collections",
  "tag": "section",
  "class": "section-grille-collections",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titre de la section (optionnel)"
    },
    {
      "type": "select",
      "id": "heading_align",
      "label": "Alignement du titre",
      "options": [
        { "value": "left", "label": "Gauche" },
        { "value": "center", "label": "Centré" }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Couleur du titre",
      "default": "#1d2153"
    },
    { "type": "header", "content": "Disposition" },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Colonnes sur PC",
      "min": 2, "max": 6, "step": 1,
      "default": 6
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "label": "Colonnes sur tablette",
      "min": 2, "max": 4, "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Colonnes sur mobile",
      "options": [
        { "value": "1", "label": "1 colonne" },
        { "value": "2", "label": "2 colonnes" }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "ratio",
      "label": "Format des images",
      "options": [
        { "value": "1 / 1", "label": "Carré (1:1)" },
        { "value": "3 / 4", "label": "Portrait (3:4)" },
        { "value": "4 / 5", "label": "Portrait doux (4:5)" },
        { "value": "4 / 3", "label": "Paysage (4:3)" }
      ],
      "default": "3 / 4"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Espace entre les vignettes (PC)",
      "min": 0, "max": 40, "step": 2, "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "label": "Espace entre les vignettes (mobile)",
      "min": 0, "max": 24, "step": 2, "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "radius",
      "label": "Arrondi des angles",
      "min": 0, "max": 24, "step": 2, "unit": "px",
      "default": 0
    },
    { "type": "header", "content": "Étiquettes" },
    {
      "type": "color",
      "id": "label_bg",
      "label": "Fond de l'étiquette",
      "default": "#b3946a"
    },
    {
      "type": "color",
      "id": "label_bg_hover",
      "label": "Fond de l'étiquette au survol",
      "default": "#9a7d55"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Texte de l'étiquette",
      "default": "#ffffff"
    },
    { "type": "header", "content": "Section" },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fond de la section",
      "default": "#faf6ef"
    },
    {
      "type": "range",
      "id": "side_padding",
      "label": "Marges latérales",
      "min": 0, "max": 60, "step": 5, "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Espace au-dessus",
      "min": 0, "max": 100, "step": 5, "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Espace en dessous",
      "min": 0, "max": 100, "step": 5, "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "carte",
      "name": "Vignette",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Si vide, l'image de la collection choisie sera utilisée."
        },
        {
          "type": "text",
          "id": "label",
          "label": "Texte de l'étiquette",
          "default": "Ma collection"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection liée"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Lien personnalisé (optionnel)",
          "info": "Prioritaire sur la collection si renseigné."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Grille de collections",
      "blocks": [
        { "type": "carte", "settings": { "label": "Les sacs à dos" } },
        { "type": "carte", "settings": { "label": "Le bain rayé" } },
        { "type": "carte", "settings": { "label": "Le repas" } },
        { "type": "carte", "settings": { "label": "Les carreaux" } },
        { "type": "carte", "settings": { "label": "Les gourdes" } },
        { "type": "carte", "settings": { "label": "Les coffrets" } }
      ]
    }
  ]
}
{% endschema %}