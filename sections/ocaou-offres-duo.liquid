{% comment %}
================================================================
  SECTION O'CAOU — Offres Duo (page produit)
  À placer dans : sections/ocaou-offres-duo.liquid

  ▸ S'ajoute sur le modèle de page PRODUIT
    (Personnaliser > Produits > Modèle par défaut > Ajouter une section)
  ▸ Chaque bloc = 1 Duo : choisissez le produit complémentaire
    (gourde, cabas, pochette), le prix Duo, les textes
  ▸ Le total barré est calculé automatiquement :
    prix du produit affiché + prix du complément
  ▸ Le bouton ajoute LES 2 PRODUITS ensemble au panier (AJAX)
  ▸ Le client choisit le coloris du complément dans la carte

  ⚠️ IMPORTANT — pour que le prix Duo s'applique au paiement :
  créez une RÉDUCTION AUTOMATIQUE dans l'admin Shopify
  (Réductions > Créer > Réduction automatique > Montant sur
  les produits > condition "achète X et Y"). La section affiche
  l'offre et ajoute les produits ; Shopify applique la remise.
================================================================
{% endcomment %}

{%- liquid
  assign uid = section.id
  assign s = section.settings
  assign main_variant = product.selected_or_first_available_variant
-%}

<style>
  #duo-{{ uid }} {
    background: {{ s.bg_color }};
    padding: {{ s.padding_top }}px 0 {{ s.padding_bottom }}px;
  }
  #duo-{{ uid }} .duo-inner {
    max-width: {{ s.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }
  #duo-{{ uid }} .duo-head { text-align: center; margin-bottom: 34px; }
  #duo-{{ uid }} .duo-eyebrow {
    display: inline-block;
    font-size: {{ s.eyebrow_size }}px;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: {{ s.accent_color }};
    margin-bottom: 10px;
  }
  #duo-{{ uid }} .duo-title {
    margin: 0 0 8px;
    font-size: {{ s.title_size }}px;
    font-weight: 700;
    color: {{ s.text_color }};
  }
  #duo-{{ uid }} .duo-subtitle {
    margin: 0;
    font-size: {{ s.subtitle_size }}px;
    color: {{ s.text_color }};
    opacity: .7;
  }

  #duo-{{ uid }} .duo-grid {
    display: grid;
    grid-template-columns: repeat({{ s.columns_desktop }}, minmax(0,1fr));
    gap: 18px;
    align-items: stretch;
  }

  #duo-{{ uid }} .duo-card {
    display: flex;
    flex-direction: column;
    background: {{ s.card_bg }};
    border: 1.5px dashed {{ s.card_border }};
    border-radius: {{ s.card_radius }}px;
    padding: 22px;
    position: relative;
  }
  #duo-{{ uid }} .duo-card.is-featured { border-style: solid; border-color: {{ s.accent_color }}; }
  #duo-{{ uid }} .duo-badge {
    position: absolute;
    top: -12px;
    left: 20px;
    background: {{ s.accent_color }};
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 999px;
  }

  #duo-{{ uid }} .duo-visuals {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin-bottom: 16px;
  }
  #duo-{{ uid }} .duo-visuals .v {
    width: 84px;
    height: 84px;
    border-radius: 14px;
    overflow: hidden;
    background: #F4EDE2;
    flex: 0 0 auto;
  }
  #duo-{{ uid }} .duo-visuals .v img { width: 100%; height: 100%; object-fit: cover; display: block; }
  #duo-{{ uid }} .duo-visuals .plus {
    font-size: 22px;
    font-weight: 700;
    color: {{ s.accent_color }};
  }

  #duo-{{ uid }} .duo-card h3 {
    margin: 0 0 4px;
    font-size: {{ s.card_title_size }}px;
    font-weight: 700;
    color: {{ s.text_color }};
    text-align: center;
  }
  #duo-{{ uid }} .duo-card .tagline {
    margin: 0 0 14px;
    font-size: {{ s.card_text_size }}px;
    color: {{ s.text_color }};
    opacity: .7;
    text-align: center;
  }
  #duo-{{ uid }} .duo-card .desc {
    margin: 0 0 16px;
    font-size: {{ s.card_text_size }}px;
    line-height: 1.5;
    color: {{ s.text_color }};
    opacity: .85;
  }

  #duo-{{ uid }} .duo-variant {
    margin-bottom: 14px;
  }
  #duo-{{ uid }} .duo-variant label {
    display: block;
    font-size: 12px;
    font-weight: 700;
    margin-bottom: 6px;
    color: {{ s.text_color }};
  }
  #duo-{{ uid }} .duo-variant select {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid {{ s.card_border }};
    border-radius: 10px;
    font-size: 14px;
    background: #fff;
    color: {{ s.text_color }};
  }

  #duo-{{ uid }} .duo-detail {
    font-size: 12.5px;
    color: {{ s.text_color }};
    opacity: .75;
    margin: 0 0 12px;
  }
  #duo-{{ uid }} .duo-detail .line { display: flex; justify-content: space-between; padding: 3px 0; }

  #duo-{{ uid }} .duo-prices {
    margin-top: auto;
    padding-top: 8px;
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 10px;
  }
  #duo-{{ uid }} .duo-prices s { font-size: 14px; opacity: .55; color: {{ s.text_color }}; }
  #duo-{{ uid }} .duo-prices .now {
    font-size: {{ s.price_size }}px;
    font-weight: 800;
    color: {{ s.accent_color }};
  }
  #duo-{{ uid }} .duo-prices .now small { font-size: 12px; font-weight: 600; color: {{ s.text_color }}; }
  #duo-{{ uid }} .duo-ship {
    text-align: center;
    font-size: 12px;
    font-weight: 700;
    color: {{ s.ship_color }};
    margin: 6px 0 14px;
  }

  #duo-{{ uid }} .duo-btn {
    display: block;
    width: 100%;
    border: none;
    cursor: pointer;
    background: {{ s.accent_color }};
    color: #fff;
    font-size: 14px;
    font-weight: 700;
    padding: 14px 18px;
    border-radius: 999px;
    transition: opacity .15s ease, transform .15s ease;
  }
  #duo-{{ uid }} .duo-btn:hover { opacity: .9; transform: translateY(1px); }
  #duo-{{ uid }} .duo-btn.is-added { background: {{ s.ship_color }}; }
  #duo-{{ uid }} .duo-btn:disabled { opacity: .6; cursor: wait; }

  @media (max-width: 989px) {
    #duo-{{ uid }} .duo-grid { grid-template-columns: 1fr; max-width: 480px; margin: 0 auto; }
  }
  @media (max-width: 749px) {
    #duo-{{ uid }} .duo-title { font-size: {{ s.title_size_mobile }}px; }
    #duo-{{ uid }} .duo-card { padding: 18px; }
  }
</style>

<div id="duo-{{ uid }}">
  <div class="duo-inner">

    <div class="duo-head">
      {% if s.eyebrow != blank %}<span class="duo-eyebrow">{{ s.eyebrow }}</span>{% endif %}
      {% if s.title != blank %}<h2 class="duo-title">{{ s.title }}</h2>{% endif %}
      {% if s.subtitle != blank %}<p class="duo-subtitle">{{ s.subtitle }}</p>{% endif %}
    </div>

    <div class="duo-grid">
      {% for block in section.blocks %}
        {%- liquid
          assign comp = block.settings.produit
          assign comp_variant = comp.selected_or_first_available_variant
          assign total = 0
          if main_variant != blank and comp_variant != blank
            assign total = main_variant.price | plus: comp_variant.price
          endif
          assign duo_price_cents = block.settings.prix_duo | times: 100
        -%}

        <div class="duo-card{% if block.settings.mis_en_avant %} is-featured{% endif %}" {{ block.shopify_attributes }}>

          {% if block.settings.badge != blank %}
            <span class="duo-badge">{{ block.settings.badge }}</span>
          {% endif %}

          <div class="duo-visuals">
            <div class="v">
              {% if product.featured_image != blank %}
                {{ product.featured_image | image_url: width: 200 | image_tag: loading: 'lazy', alt: product.title }}
              {% endif %}
            </div>
            <span class="plus">+</span>
            <div class="v">
              {% if comp != blank and comp.featured_image != blank %}
                {{ comp.featured_image | image_url: width: 200 | image_tag: loading: 'lazy', alt: comp.title }}
              {% endif %}
            </div>
          </div>

          <h3>{{ block.settings.titre }}</h3>
          {% if block.settings.tagline != blank %}
            <p class="tagline">{{ block.settings.tagline }}</p>
          {% endif %}
          {% if block.settings.description != blank %}
            <p class="desc">{{ block.settings.description }}</p>
          {% endif %}

          {% if comp != blank %}
            {% if comp.variants.size > 1 %}
              <div class="duo-variant">
                <label for="duo-var-{{ uid }}-{{ forloop.index }}">Coloris {{ comp.title | downcase }}</label>
                <select id="duo-var-{{ uid }}-{{ forloop.index }}" class="duo-comp-variant">
                  {% for v in comp.variants %}
                    <option value="{{ v.id }}" {% unless v.available %}disabled{% endunless %}>
                      {{ v.title }}{% unless v.available %} — épuisé{% endunless %}
                    </option>
                  {% endfor %}
                </select>
              </div>
            {% endif %}

            <div class="duo-detail">
              <div class="line"><span>{{ product.title }}</span><span>{{ main_variant.price | money }}</span></div>
              <div class="line"><span>{{ comp.title }}</span><span>{{ comp_variant.price | money }}</span></div>
            </div>

            <div class="duo-prices">
              {% if total > duo_price_cents %}<s>{{ total | money }}</s>{% endif %}
              <span class="now">{{ duo_price_cents | money }} <small>Prix Duo</small></span>
            </div>
            <p class="duo-ship">🚚 Livraison offerte</p>

            <button
              type="button"
              class="duo-btn"
              data-main-variant="{{ main_variant.id }}"
              data-comp-variant="{{ comp_variant.id }}"
              {% unless main_variant.available and comp_variant.available %}disabled{% endunless %}>
              {% if main_variant.available and comp_variant.available %}
                {{ block.settings.texte_bouton | default: 'Ajouter le Duo au panier' }}
              {% else %}
                Duo indisponible
              {% endif %}
            </button>
          {% else %}
            <p class="desc" style="text-align:center">⚠️ Choisissez le produit complémentaire dans les réglages du bloc.</p>
          {% endif %}

        </div>
      {% endfor %}
    </div>

  </div>
</div>

<script>
(function () {
  var section = document.getElementById('duo-{{ uid }}');
  if (!section) return;

  section.querySelectorAll('.duo-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var card = btn.closest('.duo-card');
      var select = card.querySelector('.duo-comp-variant');
      var compId = select ? select.value : btn.dataset.compVariant;
      var mainId = btn.dataset.mainVariant;
      if (!mainId || !compId) return;

      var initial = btn.textContent;
      btn.disabled = true;
      btn.textContent = 'Ajout en cours…';

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          items: [
            { id: parseInt(mainId, 10), quantity: 1 },
            { id: parseInt(compId, 10), quantity: 1 }
          ]
        })
      })
      .then(function (r) { if (!r.ok) throw new Error(); return r.json(); })
      .then(function () {
        btn.classList.add('is-added');
        btn.textContent = '✓ Duo ajouté au panier';
        btn.disabled = false;
        document.dispatchEvent(new CustomEvent('cart:refresh', { bubbles: true }));
        {% if s.redirection_panier %}
        window.location.href = '/cart';
        {% endif %}
        setTimeout(function () {
          btn.classList.remove('is-added');
          btn.textContent = initial;
        }, 4000);
      })
      .catch(function () {
        btn.disabled = false;
        btn.textContent = 'Erreur — réessayez';
        setTimeout(function () { btn.textContent = initial; }, 3000);
      });
    });
  });
})();
</script>

{% schema %}
{
  "name": "Offres Duo O'CAOU",
  "tag": "section",
  "class": "section-offres-duo",
  "enabled_on": {
    "templates": ["product"]
  },
  "max_blocks": 4,
  "settings": [
    { "type": "header", "content": "Titres" },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Sur-titre",
      "default": "Prix exclusifs Duo"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Complétez votre sac avec un indispensable"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "Et profitez des prix exclusifs Duo — livraison offerte 🚚"
    },
    { "type": "header", "content": "Comportement" },
    {
      "type": "checkbox",
      "id": "redirection_panier",
      "label": "Rediriger vers le panier après l'ajout",
      "default": false
    },
    { "type": "header", "content": "Disposition" },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Colonnes sur PC",
      "min": 1, "max": 4, "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Largeur maximum",
      "min": 800, "max": 1600, "step": 20,
      "default": 1200
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Arrondi des cartes",
      "min": 0, "max": 30, "step": 2, "unit": "px",
      "default": 16
    },
    { "type": "header", "content": "Tailles des textes" },
    {
      "type": "range",
      "id": "eyebrow_size",
      "label": "Taille sur-titre",
      "min": 9, "max": 20, "step": 1, "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Taille titre (PC)",
      "min": 18, "max": 48, "step": 1, "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "label": "Taille titre (mobile)",
      "min": 16, "max": 34, "step": 1, "unit": "px",
      "default": 22
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "label": "Taille sous-titre",
      "min": 12, "max": 24, "step": 1, "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "card_title_size",
      "label": "Taille titre des cartes",
      "min": 14, "max": 28, "step": 1, "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "card_text_size",
      "label": "Taille textes des cartes",
      "min": 11, "max": 18, "step": 1, "unit": "px",
      "default": 13
    },
    {
      "type": "range",
      "id": "price_size",
      "label": "Taille du prix Duo",
      "min": 16, "max": 36, "step": 1, "unit": "px",
      "default": 24
    },
    { "type": "header", "content": "Couleurs" },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fond de la section",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Fond des cartes",
      "default": "#FDFBF7"
    },
    {
      "type": "color",
      "id": "card_border",
      "label": "Bordure des cartes",
      "default": "#E5D8C8"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur des textes",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Couleur accent (prix, bouton, badge)",
      "default": "#B3565A"
    },
    {
      "type": "color",
      "id": "ship_color",
      "label": "Couleur livraison offerte / confirmation",
      "default": "#1EA97C"
    },
    { "type": "header", "content": "Espacements" },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Espace au-dessus",
      "min": 0, "max": 120, "step": 4,
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Espace en dessous",
      "min": 0, "max": 120, "step": 4,
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "duo",
      "name": "Duo",
      "settings": [
        {
          "type": "product",
          "id": "produit",
          "label": "Produit complémentaire",
          "info": "La gourde, le cabas ou la pochette. Ses coloris (variantes) seront proposés au client."
        },
        {
          "type": "text",
          "id": "titre",
          "label": "Titre du Duo",
          "default": "Le Duo Gourde"
        },
        {
          "type": "text",
          "id": "tagline",
          "label": "Accroche",
          "default": "L'indispensable pour les Petits Grands"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "La gourde O'CAOU qui survit aux enfants : en silicone, incassable et durable pour toutes vos aventures."
        },
        {
          "type": "number",
          "id": "prix_duo",
          "label": "Prix Duo (en euros)",
          "default": 89,
          "info": "Ex : 89. Le total barré est calculé automatiquement. Pensez à créer la réduction automatique correspondante dans Réductions."
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge (optionnel)",
          "info": "Ex : Le préféré ♥"
        },
        {
          "type": "checkbox",
          "id": "mis_en_avant",
          "label": "Mettre en avant (bordure pleine accent)",
          "default": false
        },
        {
          "type": "text",
          "id": "texte_bouton",
          "label": "Texte du bouton",
          "default": "Ajouter le Duo au panier"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Offres Duo O'CAOU",
      "blocks": [
        {
          "type": "duo",
          "settings": {
            "titre": "Le Duo Gourde",
            "tagline": "L'indispensable pour les Petits Grands",
            "description": "La gourde O'CAOU qui survit aux enfants : en silicone, incassable et durable pour toutes vos aventures.",
            "prix_duo": 89,
            "badge": "Le préféré ♥",
            "mis_en_avant": true
          }
        },
        {
          "type": "duo",
          "settings": {
            "titre": "Le Duo Cabas",
            "tagline": "Pour des parents organisés",
            "description": "Un grand cabas fourre-tout 100% coton (30x40 cm), durable et réutilisable, pour tout emporter : jouets, affaires, doudou, chaussures…",
            "prix_duo": 99
          }
        },
        {
          "type": "duo",
          "settings": {
            "titre": "Le Duo Pochette",
            "tagline": "Pratique pour tout ranger",
            "description": "Une pochette pratique 100% coton (30x40 cm), durable et réutilisable, pensée pour vous simplifier le quotidien.",
            "prix_duo": 89
          }
        }
      ]
    }
  ]
}
{% endschema %}