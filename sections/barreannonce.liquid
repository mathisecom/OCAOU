{% style %}
  #shopify-section-{{ section.id }} .fp-announcement-bar {
    width: 100%;
    background: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .fp-announcement-inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 {{ section.settings.side_padding_desktop }}px;
    display: flex;
    align-items: center;
    justify-content: {{ section.settings.desktop_alignment }};
    gap: {{ section.settings.item_gap_desktop }}px;
  }

  #shopify-section-{{ section.id }} .fp-announcement-item {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: {{ section.settings.icon_text_gap }}px;
    white-space: nowrap;
    color: {{ section.settings.text_color }};
    font-size: {{ section.settings.font_size_desktop }}px;
    font-weight: {{ section.settings.font_weight }};
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .fp-announcement-link {
    text-decoration: none;
    color: inherit;
  }

  #shopify-section-{{ section.id }} .fp-announcement-icon {
    width: {{ section.settings.icon_circle_size_desktop }}px;
    height: {{ section.settings.icon_circle_size_desktop }}px;
    min-width: {{ section.settings.icon_circle_size_desktop }}px;
    border-radius: 999px;
    background: {{ section.settings.icon_bg_color }};
    color: {{ section.settings.icon_color }};
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .fp-announcement-icon svg {
    width: {{ section.settings.icon_size_desktop }}px;
    height: {{ section.settings.icon_size_desktop }}px;
    display: block;
  }

  #shopify-section-{{ section.id }} .fp-announcement-text {
    color: {{ section.settings.text_color }};
  }

  #shopify-section-{{ section.id }} .fp-announcement-separator {
    width: 1px;
    height: {{ section.settings.separator_height }}px;
    background: {{ section.settings.separator_color }};
    opacity: {{ section.settings.separator_opacity | divided_by: 100.0 }};
    flex: 0 0 auto;
  }

  {% unless section.settings.show_separators %}
    #shopify-section-{{ section.id }} .fp-announcement-separator {
      display: none;
    }
  {% endunless %}

  {% if section.settings.desktop_full_width %}
    #shopify-section-{{ section.id }} .fp-announcement-inner {
      max-width: none;
    }
  {% endif %}

  @media screen and (max-width: 989px) {
    #shopify-section-{{ section.id }} .fp-announcement-bar {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }

    #shopify-section-{{ section.id }} .fp-announcement-inner {
      padding: 0 {{ section.settings.side_padding_mobile }}px;
      gap: {{ section.settings.item_gap_mobile }}px;
    }

    #shopify-section-{{ section.id }} .fp-announcement-item {
      font-size: {{ section.settings.font_size_mobile }}px;
      gap: {{ section.settings.icon_text_gap_mobile }}px;
    }

    #shopify-section-{{ section.id }} .fp-announcement-icon {
      width: {{ section.settings.icon_circle_size_mobile }}px;
      height: {{ section.settings.icon_circle_size_mobile }}px;
      min-width: {{ section.settings.icon_circle_size_mobile }}px;
    }

    #shopify-section-{{ section.id }} .fp-announcement-icon svg {
      width: {{ section.settings.icon_size_mobile }}px;
      height: {{ section.settings.icon_size_mobile }}px;
    }

    {% if section.settings.mobile_layout == 'scroll' %}
      #shopify-section-{{ section.id }} .fp-announcement-inner {
        justify-content: flex-start;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        scrollbar-width: none;
        -ms-overflow-style: none;
      }

      #shopify-section-{{ section.id }} .fp-announcement-inner::-webkit-scrollbar {
        display: none;
      }

      #shopify-section-{{ section.id }} .fp-announcement-item {
        scroll-snap-align: center;
      }
    {% endif %}

    {% if section.settings.mobile_layout == 'stack' %}
      #shopify-section-{{ section.id }} .fp-announcement-inner {
        flex-direction: column;
        justify-content: center;
        align-items: center;
      }

      #shopify-section-{{ section.id }} .fp-announcement-separator {
        display: none;
      }

      #shopify-section-{{ section.id }} .fp-announcement-item {
        white-space: normal;
        text-align: center;
      }
    {% endif %}

    {% if section.settings.mobile_layout == 'one_line' %}
      #shopify-section-{{ section.id }} .fp-announcement-inner {
        justify-content: center;
      }

      #shopify-section-{{ section.id }} .fp-announcement-link:not(:first-child),
      #shopify-section-{{ section.id }} .fp-announcement-inner > .fp-announcement-item:not(:first-child),
      #shopify-section-{{ section.id }} .fp-announcement-separator {
        display: none;
      }
    {% endif %}
  }
{% endstyle %}

<section class="fp-announcement-bar">
  <div class="fp-announcement-inner">

    {% for block in section.blocks %}

      {% capture item_content %}
        <div class="fp-announcement-item" {{ block.shopify_attributes }}>
          {% if block.settings.show_icon %}
            <span class="fp-announcement-icon">
              {% case block.settings.icon %}

                {% when 'truck' %}
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M3 7.5C3 6.67 3.67 6 4.5 6H14V17H3V7.5Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
                    <path d="M14 10H17.6L21 13.4V17H14V10Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
                    <path d="M7 20C8.1 20 9 19.1 9 18C9 16.9 8.1 16 7 16C5.9 16 5 16.9 5 18C5 19.1 5.9 20 7 20Z" stroke="currentColor" stroke-width="1.7"/>
                    <path d="M17.5 20C18.6 20 19.5 19.1 19.5 18C19.5 16.9 18.6 16 17.5 16C16.4 16 15.5 16.9 15.5 18C15.5 19.1 16.4 20 17.5 20Z" stroke="currentColor" stroke-width="1.7"/>
                  </svg>

                {% when 'box' %}
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M4 7.5L12 3.5L20 7.5V16.5L12 20.5L4 16.5V7.5Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
                    <path d="M4 7.5L12 11.5L20 7.5" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
                    <path d="M12 11.5V20.5" stroke="currentColor" stroke-width="1.7"/>
                  </svg>

                {% when 'gift' %}
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M4 10H20V20H4V10Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
                    <path d="M3 6H21V10H3V6Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
                    <path d="M12 6V20" stroke="currentColor" stroke-width="1.7"/>
                    <path d="M12 6C10.6 3.8 8 3.8 8 5.3C8 6.2 8.8 6.8 10.1 6.8H12Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
                    <path d="M12 6C13.4 3.8 16 3.8 16 5.3C16 6.2 15.2 6.8 13.9 6.8H12Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
                  </svg>

                {% when 'return' %}
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M9 7L5 11L9 15" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M5 11H15C17.8 11 20 13.2 20 16C20 18.8 17.8 21 15 21H10" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M7 3H19V10" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>

                {% when 'shield' %}
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M12 3L19 6V11.5C19 16.2 16.1 19.5 12 21C7.9 19.5 5 16.2 5 11.5V6L12 3Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
                    <path d="M9 12L11 14L15.5 9.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>

                {% else %}
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M12 21C12 21 19 16.6 19 10.5C19 6.9 16.1 4 12.5 4C10.5 4 8.8 4.9 7.7 6.3C6.6 4.9 4.9 4 3 4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
                    <path d="M5 8C5 13.6 12 21 12 21" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
                  </svg>

              {% endcase %}
            </span>
          {% endif %}

          {% if block.settings.text != blank %}
            <span class="fp-announcement-text">
              {{ block.settings.text }}
            </span>
          {% endif %}
        </div>
      {% endcapture %}

      {% if block.settings.link != blank %}
        <a href="{{ block.settings.link }}" class="fp-announcement-link">
          {{ item_content }}
        </a>
      {% else %}
        {{ item_content }}
      {% endif %}

      {% unless forloop.last %}
        <span class="fp-announcement-separator"></span>
      {% endunless %}

    {% endfor %}

  </div>
</section>

{% schema %}
{
  "name": "Barre annonce avantages",
  "settings": [
    {
      "type": "header",
      "content": "Disposition générale"
    },
    {
      "type": "checkbox",
      "id": "desktop_full_width",
      "label": "Prendre toute la largeur de l’écran",
      "default": true
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Largeur maximale si pleine largeur désactivée",
      "min": 800,
      "max": 2200,
      "step": 50,
      "default": 1600
    },
    {
      "type": "select",
      "id": "desktop_alignment",
      "label": "Alignement PC",
      "default": "center",
      "options": [
        {
          "value": "flex-start",
          "label": "Gauche"
        },
        {
          "value": "center",
          "label": "Centre"
        },
        {
          "value": "space-between",
          "label": "Espacé"
        }
      ]
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Affichage mobile",
      "default": "scroll",
      "options": [
        {
          "value": "scroll",
          "label": "Défilement horizontal"
        },
        {
          "value": "stack",
          "label": "Empilé"
        },
        {
          "value": "one_line",
          "label": "Afficher uniquement le premier message"
        }
      ]
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Couleur de fond",
      "default": "#aa9988"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur du texte",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "icon_bg_color",
      "label": "Fond rond des icônes",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Couleur des icônes",
      "default": "#aa9988"
    },
    {
      "type": "header",
      "content": "Typographie"
    },
    {
      "type": "range",
      "id": "font_size_desktop",
      "label": "Taille du texte PC",
      "min": 10,
      "max": 24,
      "step": 1,
      "default": 13
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "label": "Taille du texte mobile",
      "min": 10,
      "max": 22,
      "step": 1,
      "default": 12
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Épaisseur du texte",
      "default": "600",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ]
    },
    {
      "type": "header",
      "content": "Icônes"
    },
    {
      "type": "range",
      "id": "icon_circle_size_desktop",
      "label": "Taille rond icône PC",
      "min": 16,
      "max": 44,
      "step": 2,
      "default": 24
    },
    {
      "type": "range",
      "id": "icon_circle_size_mobile",
      "label": "Taille rond icône mobile",
      "min": 16,
      "max": 44,
      "step": 2,
      "default": 22
    },
    {
      "type": "range",
      "id": "icon_size_desktop",
      "label": "Taille icône PC",
      "min": 10,
      "max": 28,
      "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "icon_size_mobile",
      "label": "Taille icône mobile",
      "min": 10,
      "max": 28,
      "step": 1,
      "default": 13
    },
    {
      "type": "range",
      "id": "icon_text_gap",
      "label": "Espace icône / texte PC",
      "min": 4,
      "max": 24,
      "step": 1,
      "default": 8
    },
    {
      "type": "range",
      "id": "icon_text_gap_mobile",
      "label": "Espace icône / texte mobile",
      "min": 4,
      "max": 24,
      "step": 1,
      "default": 7
    },
    {
      "type": "header",
      "content": "Espacements"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding haut PC",
      "min": 0,
      "max": 40,
      "step": 1,
      "default": 6
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding bas PC",
      "min": 0,
      "max": 40,
      "step": 1,
      "default": 6
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding haut mobile",
      "min": 0,
      "max": 40,
      "step": 1,
      "default": 8
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bas mobile",
      "min": 0,
      "max": 40,
      "step": 1,
      "default": 8
    },
    {
      "type": "range",
      "id": "side_padding_desktop",
      "label": "Marge gauche/droite PC",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 24
    },
    {
      "type": "range",
      "id": "side_padding_mobile",
      "label": "Marge gauche/droite mobile",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 14
    },
    {
      "type": "range",
      "id": "item_gap_desktop",
      "label": "Espace entre les éléments PC",
      "min": 8,
      "max": 120,
      "step": 2,
      "default": 42
    },
    {
      "type": "range",
      "id": "item_gap_mobile",
      "label": "Espace entre les éléments mobile",
      "min": 8,
      "max": 80,
      "step": 2,
      "default": 26
    },
    {
      "type": "header",
      "content": "Séparateurs"
    },
    {
      "type": "checkbox",
      "id": "show_separators",
      "label": "Afficher les séparateurs",
      "default": true
    },
    {
      "type": "color",
      "id": "separator_color",
      "label": "Couleur des séparateurs",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "separator_height",
      "label": "Hauteur des séparateurs",
      "min": 8,
      "max": 32,
      "step": 1,
      "default": 15
    },
    {
      "type": "range",
      "id": "separator_opacity",
      "label": "Opacité des séparateurs",
      "min": 10,
      "max": 100,
      "step": 5,
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Message",
      "settings": [
        {
          "type": "checkbox",
          "id": "show_icon",
          "label": "Afficher l’icône",
          "default": true
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icône",
          "default": "truck",
          "options": [
            {
              "value": "truck",
              "label": "Camion / Livraison"
            },
            {
              "value": "box",
              "label": "Colis"
            },
            {
              "value": "gift",
              "label": "Cadeau"
            },
            {
              "value": "return",
              "label": "Retour"
            },
            {
              "value": "shield",
              "label": "Garantie"
            },
            {
              "value": "heart",
              "label": "Cœur"
            }
          ]
        },
        {
          "type": "text",
          "id": "text",
          "label": "Texte",
          "default": "Livraison* et retours gratuits"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Lien optionnel"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Barre annonce avantages",
      "blocks": [
        {
          "type": "announcement",
          "settings": {
            "icon": "truck",
            "text": "Livraison* et retours gratuits"
          }
        },
        {
          "type": "announcement",
          "settings": {
            "icon": "box",
            "text": "Emballé avec soin, généralement livré sous 2 à 5 jours ouvrés"
          }
        },
        {
          "type": "announcement",
          "settings": {
            "icon": "gift",
            "text": "Délai de réflexion de 30 jours"
          }
        }
      ]
    }
  ]
}
{% endschema %}