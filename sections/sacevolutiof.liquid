{% style %}
  #shopify-section-{{ section.id }} .fp-bag-tabs-section {
    background: {{ section.settings.section_bg }};
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .fp-bag-tabs-container {
    max-width: {% if section.settings.full_width %}none{% else %}{{ section.settings.max_width }}px{% endif %};
    margin: 0 auto;
    padding-left: {{ section.settings.side_padding_desktop }}px;
    padding-right: {{ section.settings.side_padding_desktop }}px;
  }

  #shopify-section-{{ section.id }} .fp-bag-tabs-card {
    position: relative;
    display: grid;
    grid-template-columns: 0.95fr 1.05fr;
    min-height: {{ section.settings.card_min_height }}px;
    border-radius: {{ section.settings.card_radius }}px;
    overflow: hidden;
    background: {{ section.settings.card_bg }};
    box-shadow: 0 {{ section.settings.shadow_y }}px {{ section.settings.shadow_blur }}px rgba(0, 0, 0, {{ section.settings.shadow_opacity | divided_by: 100.0 }});
  }

  #shopify-section-{{ section.id }} .fp-bag-tabs-content {
    position: relative;
    z-index: 2;
    padding: {{ section.settings.content_padding_y }}px {{ section.settings.content_padding_x }}px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .fp-bag-tabs-kicker {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    gap: 8px;
    margin-bottom: 14px;
    padding: 8px 14px;
    border-radius: 999px;
    background: {{ section.settings.kicker_bg }};
    color: {{ section.settings.kicker_color }};
    font-size: {{ section.settings.kicker_size }}px;
    font-weight: 700;
    line-height: 1;
  }

  #shopify-section-{{ section.id }} .fp-bag-tabs-title {
    margin: 0;
    color: {{ section.settings.title_color }};
    font-size: {{ section.settings.title_size_desktop }}px;
    font-weight: {{ section.settings.title_weight }};
    line-height: 1.08;
    letter-spacing: -0.03em;
  }

  #shopify-section-{{ section.id }} .fp-bag-tabs-title span {
    color: {{ section.settings.highlight_color }};
    display: block;
  }

  #shopify-section-{{ section.id }} .fp-bag-tabs-text {
    margin: 18px 0 0;
    max-width: {{ section.settings.text_max_width }}px;
    color: {{ section.settings.text_color }};
    font-size: {{ section.settings.text_size_desktop }}px;
    line-height: 1.45;
  }

  #shopify-section-{{ section.id }} .fp-bag-tabs-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: {{ section.settings.button_gap }}px;
    margin-top: {{ section.settings.buttons_margin_top }}px;
  }

  #shopify-section-{{ section.id }} .fp-bag-tab-button {
    appearance: none;
    border: 1px solid {{ section.settings.button_border }};
    background: {{ section.settings.button_bg }};
    color: {{ section.settings.button_text }};
    border-radius: {{ section.settings.button_radius }}px;
    padding: {{ section.settings.button_padding_y }}px {{ section.settings.button_padding_x }}px;
    font-size: {{ section.settings.button_size }}px;
    font-weight: 600;
    line-height: 1;
    cursor: pointer;
    transition: all 0.25s ease;
    white-space: nowrap;
    box-shadow: 0 8px 22px rgba(0,0,0,0.04);
  }

  #shopify-section-{{ section.id }} .fp-bag-tab-button:hover,
  #shopify-section-{{ section.id }} .fp-bag-tab-button.is-active {
    background: {{ section.settings.button_active_bg }};
    color: {{ section.settings.button_active_text }};
    border-color: {{ section.settings.button_active_bg }};
    transform: translateY(-2px);
  }

  #shopify-section-{{ section.id }} .fp-bag-tabs-image-zone {
    position: relative;
    min-height: {{ section.settings.card_min_height }}px;
    background: {{ section.settings.image_bg }};
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .fp-bag-tabs-image-zone::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 20% 20%, rgba(255,255,255,0.55), transparent 28%),
      linear-gradient(135deg, rgba(255,255,255,0.12), rgba(0,0,0,0.04));
    z-index: 1;
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .fp-bag-tabs-image-panel {
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: scale(1.04);
    transition: opacity 0.45s ease, transform 0.6s ease;
  }

  #shopify-section-{{ section.id }} .fp-bag-tabs-image-panel.is-active {
    opacity: 1;
    transform: scale(1);
    z-index: 2;
  }

  #shopify-section-{{ section.id }} .fp-bag-tabs-image-panel img {
    width: 100%;
    height: 100%;
    object-fit: {{ section.settings.image_fit }};
    object-position: {{ section.settings.image_position }};
    display: block;
  }

  #shopify-section-{{ section.id }} .fp-bag-tabs-placeholder {
    width: 100%;
    height: 100%;
    min-height: {{ section.settings.card_min_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: {{ section.settings.image_bg }};
    color: {{ section.settings.text_color }};
    padding: 24px;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .fp-bag-tabs-floating {
    position: absolute;
    right: 22px;
    bottom: 22px;
    z-index: 4;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 11px 16px;
    border-radius: 999px;
    background: {{ section.settings.float_bg }};
    color: {{ section.settings.float_text_color }};
    font-size: 13px;
    font-weight: 700;
    box-shadow: 0 14px 35px rgba(0,0,0,0.12);
    backdrop-filter: blur(10px);
  }

  #shopify-section-{{ section.id }} .fp-bag-tabs-floating svg {
    width: 16px;
    height: 16px;
    display: block;
  }

  @media screen and (max-width: 989px) {
    #shopify-section-{{ section.id }} .fp-bag-tabs-section {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }

    #shopify-section-{{ section.id }} .fp-bag-tabs-container {
      padding-left: {{ section.settings.side_padding_mobile }}px;
      padding-right: {{ section.settings.side_padding_mobile }}px;
    }

    #shopify-section-{{ section.id }} .fp-bag-tabs-card {
      grid-template-columns: 1fr;
      border-radius: {{ section.settings.card_radius_mobile }}px;
      min-height: auto;
    }

    #shopify-section-{{ section.id }} .fp-bag-tabs-image-zone {
      order: 1;
      min-height: {{ section.settings.mobile_image_height }}px;
    }

    #shopify-section-{{ section.id }} .fp-bag-tabs-placeholder {
      min-height: {{ section.settings.mobile_image_height }}px;
    }

    #shopify-section-{{ section.id }} .fp-bag-tabs-content {
      order: 2;
      padding: {{ section.settings.content_padding_y_mobile }}px {{ section.settings.content_padding_x_mobile }}px;
      text-align: {{ section.settings.mobile_text_align }};
      align-items: {% if section.settings.mobile_text_align == 'center' %}center{% else %}flex-start{% endif %};
    }

    #shopify-section-{{ section.id }} .fp-bag-tabs-title {
      font-size: {{ section.settings.title_size_mobile }}px;
      line-height: 1.05;
    }

    #shopify-section-{{ section.id }} .fp-bag-tabs-text {
      font-size: {{ section.settings.text_size_mobile }}px;
      margin-top: 12px;
    }

    #shopify-section-{{ section.id }} .fp-bag-tabs-buttons {
      width: 100%;
      flex-wrap: nowrap;
      overflow-x: auto;
      gap: {{ section.settings.button_gap_mobile }}px;
      margin-top: {{ section.settings.buttons_margin_top_mobile }}px;
      padding-bottom: 8px;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }

    #shopify-section-{{ section.id }} .fp-bag-tabs-buttons::-webkit-scrollbar {
      display: none;
    }

    #shopify-section-{{ section.id }} .fp-bag-tab-button {
      flex: 0 0 auto;
      scroll-snap-align: start;
      padding: {{ section.settings.button_padding_y_mobile }}px {{ section.settings.button_padding_x_mobile }}px;
      font-size: {{ section.settings.button_size_mobile }}px;
      border-radius: {{ section.settings.button_radius_mobile }}px;
    }

    #shopify-section-{{ section.id }} .fp-bag-tabs-floating {
      right: 14px;
      bottom: 14px;
      font-size: 12px;
      padding: 9px 13px;
    }
  }
{% endstyle %}

<section class="fp-bag-tabs-section">
  <div class="fp-bag-tabs-container">
    <div class="fp-bag-tabs-card" data-fp-bag-tabs="{{ section.id }}">

      <div class="fp-bag-tabs-content">
        {% if section.settings.kicker != blank %}
          <div class="fp-bag-tabs-kicker">
            {{ section.settings.kicker }}
          </div>
        {% endif %}

        {% if section.settings.title != blank %}
          <h2 class="fp-bag-tabs-title">
            {{ section.settings.title }}
            {% if section.settings.highlight_title != blank %}
              <span>{{ section.settings.highlight_title }}</span>
            {% endif %}
          </h2>
        {% endif %}

        {% if section.settings.text != blank %}
          <p class="fp-bag-tabs-text">
            {{ section.settings.text }}
          </p>
        {% endif %}

        <div class="fp-bag-tabs-buttons" role="tablist">
          {% for block in section.blocks %}
            <button
              class="fp-bag-tab-button {% if forloop.first %}is-active{% endif %}"
              type="button"
              data-tab-index="{{ forloop.index0 }}"
              role="tab"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.button_text }}
            </button>
          {% endfor %}
        </div>
      </div>

      <div class="fp-bag-tabs-image-zone">
        {% for block in section.blocks %}
          <div class="fp-bag-tabs-image-panel {% if forloop.first %}is-active{% endif %}" data-image-index="{{ forloop.index0 }}">
            {% if block.settings.image != blank %}
              <img
                src="{{ block.settings.image | image_url: width: 1400 }}"
                alt="{{ block.settings.image_alt | escape }}"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                width="1400"
                height="1000"
              >
            {% else %}
              <div class="fp-bag-tabs-placeholder">
                Ajoute une image pour : {{ block.settings.button_text }}
              </div>
            {% endif %}
          </div>
        {% endfor %}

        {% if section.settings.show_float_badge %}
          <div class="fp-bag-tabs-floating">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 3L14.6 8.7L21 9.4L16.2 13.7L17.5 20L12 16.8L6.5 20L7.8 13.7L3 9.4L9.4 8.7L12 3Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
            </svg>
            {{ section.settings.float_text }}
          </div>
        {% endif %}
      </div>

    </div>
  </div>
</section>

<script>
  function initFpBagTabs(sectionId) {
    const section = document.querySelector('#shopify-section-' + sectionId);
    if (!section) return;

    const buttons = section.querySelectorAll('.fp-bag-tab-button');
    const panels = section.querySelectorAll('.fp-bag-tabs-image-panel');

    buttons.forEach(function(button) {
      button.addEventListener('click', function() {
        const index = button.getAttribute('data-tab-index');

        buttons.forEach(function(btn) {
          btn.classList.remove('is-active');
          btn.setAttribute('aria-selected', 'false');
        });

        panels.forEach(function(panel) {
          panel.classList.remove('is-active');
        });

        button.classList.add('is-active');
        button.setAttribute('aria-selected', 'true');

        const activePanel = section.querySelector('.fp-bag-tabs-image-panel[data-image-index="' + index + '"]');
        if (activePanel) {
          activePanel.classList.add('is-active');
        }

        if (window.innerWidth < 990) {
          button.scrollIntoView({
            behavior: 'smooth',
            inline: 'center',
            block: 'nearest'
          });
        }
      });
    });
  }

  document.addEventListener('DOMContentLoaded', function() {
    initFpBagTabs('{{ section.id }}');
  });

  document.addEventListener('shopify:section:load', function(event) {
    if (event.detail.sectionId === '{{ section.id }}') {
      initFpBagTabs('{{ section.id }}');
    }
  });
</script>

