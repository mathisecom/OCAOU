{% style %}
  #shopify-section-{{ section.id }} .fp-reviews-section {
    background: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .fp-reviews-container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 {{ section.settings.side_padding_desktop }}px;
  }

  #shopify-section-{{ section.id }} .fp-reviews-header {
    text-align: center;
    margin-bottom: {{ section.settings.header_margin }}px;
  }

  #shopify-section-{{ section.id }} .fp-reviews-stars-top {
    font-size: {{ section.settings.top_stars_size }}px;
    letter-spacing: 2px;
    color: {{ section.settings.star_color }};
    line-height: 1;
    margin-bottom: 14px;
  }

  #shopify-section-{{ section.id }} .fp-reviews-title {
    margin: 0;
    font-size: {{ section.settings.title_size_desktop }}px;
    font-weight: {{ section.settings.title_weight }};
    color: {{ section.settings.title_color }};
    text-transform: uppercase;
    letter-spacing: {{ section.settings.title_letter_spacing }}px;
  }

  #shopify-section-{{ section.id }} .fp-reviews-wrapper {
    position: relative;
  }

  #shopify-section-{{ section.id }} .fp-reviews-track {
    display: flex;
    gap: {{ section.settings.card_gap }}px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-bottom: 6px;
  }

  #shopify-section-{{ section.id }} .fp-reviews-track::-webkit-scrollbar {
    display: none;
  }

  #shopify-section-{{ section.id }} .fp-review-card {
    flex: 0 0 calc(
      (100% - ({{ section.settings.columns_desktop | minus: 1 }} * {{ section.settings.card_gap }}px))
      / {{ section.settings.columns_desktop }}
    );
    height: {{ section.settings.card_height_desktop }}px;
    border-radius: {{ section.settings.card_radius }}px;
    overflow: hidden;
    background: {{ section.settings.card_bg_color }};
    box-shadow: 0 {{ section.settings.shadow_y }}px {{ section.settings.shadow_blur }}px rgba(0, 0, 0, {{ section.settings.shadow_opacity | divided_by: 100.0 }});
  }

  #shopify-section-{{ section.id }} .fp-review-text-card {
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: {{ section.settings.text_card_padding }}px;
    color: {{ section.settings.text_color }};
  }

  #shopify-section-{{ section.id }} .fp-review-text-inner {
    max-width: 92%;
  }

  #shopify-section-{{ section.id }} .fp-review-quote {
    font-size: {{ section.settings.quote_size_desktop }}px;
    line-height: 1.28;
    margin: 0 0 34px;
    color: {{ section.settings.text_color }};
  }

  #shopify-section-{{ section.id }} .fp-review-author {
    font-size: {{ section.settings.author_size_desktop }}px;
    margin: 0 0 8px;
    color: {{ section.settings.author_color }};
  }

  #shopify-section-{{ section.id }} .fp-review-stars {
    font-size: {{ section.settings.review_stars_size }}px;
    letter-spacing: 4px;
    color: {{ section.settings.review_star_color }};
    line-height: 1;
  }

  #shopify-section-{{ section.id }} .fp-review-image-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #shopify-section-{{ section.id }} .fp-review-placeholder {
    width: 100%;
    height: 100%;
    background: {{ section.settings.card_bg_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ section.settings.text_color }};
    font-size: 14px;
    padding: 20px;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .fp-reviews-arrows {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: {{ section.settings.arrows_margin_top }}px;
  }

  #shopify-section-{{ section.id }} .fp-review-arrow {
    width: {{ section.settings.arrow_size }}px;
    height: {{ section.settings.arrow_size }}px;
    border-radius: 999px;
    border: 1px solid {{ section.settings.arrow_border }};
    background: {{ section.settings.arrow_bg }};
    color: {{ section.settings.arrow_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.25s ease;
    padding: 0;
  }

  #shopify-section-{{ section.id }} .fp-review-arrow:hover {
    background: {{ section.settings.arrow_hover_bg }};
    color: {{ section.settings.arrow_hover_color }};
    border-color: {{ section.settings.arrow_hover_bg }};
  }

  #shopify-section-{{ section.id }} .fp-review-arrow svg {
    width: 18px;
    height: 18px;
  }

  @media screen and (max-width: 989px) {
    #shopify-section-{{ section.id }} .fp-reviews-section {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }

    #shopify-section-{{ section.id }} .fp-reviews-container {
      padding: 0 {{ section.settings.side_padding_mobile }}px;
    }

    #shopify-section-{{ section.id }} .fp-reviews-title {
      font-size: {{ section.settings.title_size_mobile }}px;
      letter-spacing: {{ section.settings.title_letter_spacing_mobile }}px;
    }

    #shopify-section-{{ section.id }} .fp-reviews-track {
      gap: {{ section.settings.card_gap_mobile }}px;
    }

    #shopify-section-{{ section.id }} .fp-review-card {
      flex: 0 0 calc(
        (100% - ({{ section.settings.columns_mobile | minus: 1 }} * {{ section.settings.card_gap_mobile }}px))
        / {{ section.settings.columns_mobile }}
      );
      height: {{ section.settings.card_height_mobile }}px;
      border-radius: {{ section.settings.card_radius_mobile }}px;
    }

    #shopify-section-{{ section.id }} .fp-review-quote {
      font-size: {{ section.settings.quote_size_mobile }}px;
      margin-bottom: 26px;
    }

    #shopify-section-{{ section.id }} .fp-review-author {
      font-size: {{ section.settings.author_size_mobile }}px;
    }

    #shopify-section-{{ section.id }} .fp-reviews-arrows {
      margin-top: {{ section.settings.arrows_margin_top_mobile }}px;
    }
  }
{% endstyle %}

<section class="fp-reviews-section">
  <div class="fp-reviews-container">

    {% if section.settings.show_header %}
      <div class="fp-reviews-header">
        {% if section.settings.show_top_stars %}
          <div class="fp-reviews-stars-top">
            ★★★★★
          </div>
        {% endif %}

        {% if section.settings.title != blank %}
          <h2 class="fp-reviews-title">
            {{ section.settings.title }}
          </h2>
        {% endif %}
      </div>
    {% endif %}

    <div class="fp-reviews-wrapper">
      <div class="fp-reviews-track" id="FpReviewsTrack-{{ section.id }}">
        {% for block in section.blocks %}
          {% case block.type %}

            {% when 'text_review' %}
              <div class="fp-review-card fp-review-text-card" {{ block.shopify_attributes }}>
                <div class="fp-review-text-inner">
                  {% if block.settings.quote != blank %}
                    <p class="fp-review-quote">
                      “{{ block.settings.quote }}”
                    </p>
                  {% endif %}

                  {% if block.settings.author != blank %}
                    <p class="fp-review-author">
                      {{ block.settings.author }}
                    </p>
                  {% endif %}

                  {% if block.settings.show_stars %}
                    <div class="fp-review-stars">
                      {% for i in (1..block.settings.stars) %}
                        ★
                      {% endfor %}
                    </div>
                  {% endif %}
                </div>
              </div>

            {% when 'image_review' %}
              <div class="fp-review-card fp-review-image-card" {{ block.shopify_attributes }}>
                {% if block.settings.image != blank %}
                  <img
                    src="{{ block.settings.image | image_url: width: 900 }}"
                    alt="{{ block.settings.image_alt | escape }}"
                    loading="lazy"
                    width="900"
                    height="900"
                  >
                {% else %}
                  <div class="fp-review-placeholder">
                    Ajoute une image dans ce bloc
                  </div>
                {% endif %}
              </div>

          {% endcase %}
        {% endfor %}
      </div>

      {% if section.settings.show_arrows %}
        <div class="fp-reviews-arrows">
          <button class="fp-review-arrow fp-review-prev" type="button" aria-label="Avis précédent">
            <svg viewBox="0 0 24 24" fill="none">
              <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          <button class="fp-review-arrow fp-review-next" type="button" aria-label="Avis suivant">
            <svg viewBox="0 0 24 24" fill="none">
              <path d="M9 6L15 12L9 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      {% endif %}
    </div>

  </div>
</section>

<script>
  function initFpReviewsCarousel(sectionId) {
    const section = document.querySelector('#shopify-section-' + sectionId);
    if (!section) return;

    const track = section.querySelector('#FpReviewsTrack-' + sectionId);
    const prev = section.querySelector('.fp-review-prev');
    const next = section.querySelector('.fp-review-next');

    if (!track || !prev || !next) return;

    function getScrollAmount() {
      const card = track.querySelector('.fp-review-card');
      if (!card) return 300;

      const gap = parseInt(window.getComputedStyle(track).gap) || 20;
      return card.offsetWidth + gap;
    }

    prev.addEventListener('click', function () {
      track.scrollBy({
        left: -getScrollAmount(),
        behavior: 'smooth'
      });
    });

    next.addEventListener('click', function () {
      track.scrollBy({
        left: getScrollAmount(),
        behavior: 'smooth'
      });
    });
  }

  document.addEventListener('DOMContentLoaded', function () {
    initFpReviewsCarousel('{{ section.id }}');
  });

  document.addEventListener('shopify:section:load', function (event) {
    if (event.detail.sectionId === '{{ section.id }}') {
      initFpReviewsCarousel('{{ section.id }}');
    }
  });
</script>

