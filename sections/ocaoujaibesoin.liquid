{% comment %}
  Section Shopify : Notre histoire / Pourquoi O'CAOU ?
  Fichier conseillé : sections/ocaou-notre-histoire.liquid
{% endcomment %}

<section
  class="ocaou-story ocaou-story--{{ section.settings.text_alignment }} ocaou-story--mobile-{{ section.settings.mobile_chip_columns }}"
  style="
    --ocaou-bg: {{ section.settings.background_color }};
    --ocaou-text: {{ section.settings.text_color }};
    --ocaou-title: {{ section.settings.title_color }};
    --ocaou-accent: {{ section.settings.accent_color }};
    --ocaou-max-width: {{ section.settings.content_width }}px;
    --ocaou-chips-width: {{ section.settings.chips_width }}px;
    --ocaou-title-size: {{ section.settings.title_size }}px;
    --ocaou-title-size-mobile: {{ section.settings.title_size_mobile }}px;
    --ocaou-subtitle-size: {{ section.settings.subtitle_size }}px;
    --ocaou-body-size: {{ section.settings.body_size }}px;
    --ocaou-chip-gap: {{ section.settings.chip_gap }}px;
    --ocaou-space-top: {{ section.settings.padding_top }}px;
    --ocaou-space-bottom: {{ section.settings.padding_bottom }}px;
    --ocaou-space-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --ocaou-space-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
  "
>
  <div class="ocaou-story__inner">
    {% if section.settings.eyebrow != blank %}
      <p class="ocaou-story__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {% endif %}

    {% if section.settings.title != blank %}
      <{{ section.settings.heading_tag }} class="ocaou-story__title">
        {{ section.settings.title | escape }}
      </{{ section.settings.heading_tag }}>
    {% endif %}

    {% if section.settings.subtitle != blank %}
      <p class="ocaou-story__subtitle">{{ section.settings.subtitle | escape }}</p>
    {% endif %}

    {% if section.settings.intro_text != blank %}
      <div class="ocaou-story__intro rte">{{ section.settings.intro_text }}</div>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="ocaou-story__chips" role="list">
        {% for block in section.blocks %}
          {% case block.settings.desktop_width %}
            {% when 'compact' %}
              {% assign chip_basis = 190 %}
            {% when 'large' %}
              {% assign chip_basis = 300 %}
            {% when 'full' %}
              {% assign chip_basis = 100 %}
            {% else %}
              {% assign chip_basis = 240 %}
          {% endcase %}

          <div
            class="ocaou-story__chip ocaou-story__chip--{{ block.settings.desktop_width }} ocaou-story__chip--icon-{{ block.settings.icon_position }}"
            role="listitem"
            style="
              --chip-bg: {{ block.settings.background_color }};
              --chip-text: {{ block.settings.text_color }};
              --chip-rotation: {{ block.settings.rotation }}deg;
              --chip-radius: {{ block.settings.border_radius }}px;
              --chip-font-size: {{ block.settings.font_size }}px;
              {% unless block.settings.desktop_width == 'full' %}
                --chip-basis: {{ chip_basis }}px;
              {% endunless %}
            "
            {{ block.shopify_attributes }}
          >
            {% if block.settings.icon != blank and block.settings.icon_position == 'left' %}
              <span class="ocaou-story__chip-icon" aria-hidden="true">{{ block.settings.icon }}</span>
            {% endif %}

            {% if block.settings.text != blank %}
              <span class="ocaou-story__chip-text">{{ block.settings.text | escape }}</span>
            {% endif %}

            {% if block.settings.icon != blank and block.settings.icon_position == 'right' %}
              <span class="ocaou-story__chip-icon" aria-hidden="true">{{ block.settings.icon }}</span>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {% if section.settings.transition_text != blank %}
      <div class="ocaou-story__transition rte">{{ section.settings.transition_text }}</div>
    {% endif %}

    {% if section.settings.challenge_prefix != blank or section.settings.challenge_highlight != blank %}
      <p class="ocaou-story__challenge">
        {% if section.settings.challenge_prefix != blank %}
          <strong>{{ section.settings.challenge_prefix | escape }}</strong>
        {% endif %}
        {% if section.settings.challenge_highlight != blank %}
          <strong class="ocaou-story__challenge-highlight">{{ section.settings.challenge_highlight | escape }}</strong>
        {% endif %}
      </p>
    {% endif %}

    {% if section.settings.main_text != blank %}
      <div class="ocaou-story__body rte">{{ section.settings.main_text }}</div>
    {% endif %}

    {% if section.settings.final_text != blank %}
      <div class="ocaou-story__body ocaou-story__body--final rte">{{ section.settings.final_text }}</div>
    {% endif %}
  </div>
</section>

<style>
  .ocaou-story {
    box-sizing: border-box;
    width: 100%;
    padding: var(--ocaou-space-top) 20px var(--ocaou-space-bottom);
    overflow: hidden;
    color: var(--ocaou-text);
    background: var(--ocaou-bg);
  }

  .ocaou-story *,
  .ocaou-story *::before,
  .ocaou-story *::after {
    box-sizing: border-box;
  }

  .ocaou-story__inner {
    width: min(100%, var(--ocaou-max-width));
    margin-inline: auto;
  }

  .ocaou-story--center {
    text-align: center;
  }

  .ocaou-story--left {
    text-align: left;
  }

  .ocaou-story__eyebrow {
    margin: 0 0 16px;
    color: var(--ocaou-accent);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.18em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .ocaou-story__title {
    margin: 0;
    color: var(--ocaou-title);
    font-size: var(--ocaou-title-size);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.1;
  }

  .ocaou-story__subtitle {
    margin: 14px 0 0;
    color: var(--ocaou-accent);
    font-size: var(--ocaou-subtitle-size);
    font-weight: 750;
    line-height: 1.3;
  }

  .ocaou-story__intro,
  .ocaou-story__transition,
  .ocaou-story__body {
    font-size: var(--ocaou-body-size);
    line-height: 1.55;
  }

  .ocaou-story__intro {
    margin-top: 32px;
  }

  .ocaou-story__chips {
    display: flex;
    flex-wrap: wrap;
    align-items: stretch;
    justify-content: center;
    gap: var(--ocaou-chip-gap);
    width: min(100%, var(--ocaou-chips-width));
    margin: 18px auto 34px;
  }

  .ocaou-story--left .ocaou-story__chips {
    justify-content: flex-start;
    margin-left: 0;
  }

  .ocaou-story__chip {
    display: inline-flex;
    flex: 0 1 var(--chip-basis, 240px);
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 12px 20px;
    gap: 8px;
    border-radius: var(--chip-radius);
    background: var(--chip-bg);
    color: var(--chip-text);
    font-size: var(--chip-font-size);
    font-weight: 650;
    line-height: 1.25;
    text-align: center;
    transform: rotate(var(--chip-rotation));
    transition: transform 180ms ease;
  }

  .ocaou-story__chip--full {
    flex-basis: 100%;
  }

  .ocaou-story__chip--icon-left {
    flex-direction: row;
  }

  .ocaou-story__chip--icon-right {
    flex-direction: row;
  }

  .ocaou-story__chip-icon {
    flex: 0 0 auto;
    font-size: 1.1em;
    line-height: 1;
  }

  .ocaou-story__chip-text {
    min-width: 0;
  }

  @media (hover: hover) {
    .ocaou-story__chip:hover {
      transform: rotate(0deg) translateY(-2px);
    }
  }

  .ocaou-story__transition {
    margin: 0 auto;
    max-width: 720px;
  }

  .ocaou-story--left .ocaou-story__transition,
  .ocaou-story--left .ocaou-story__body {
    margin-left: 0;
  }

  .ocaou-story__challenge {
    margin: 30px 0 0;
    color: var(--ocaou-title);
    font-size: calc(var(--ocaou-body-size) + 2px);
    line-height: 1.35;
  }

  .ocaou-story__challenge-highlight {
    color: var(--ocaou-accent);
  }

  .ocaou-story__body {
    max-width: 760px;
    margin: 26px auto 0;
  }

  .ocaou-story__body--final {
    margin-top: 16px;
  }

  .ocaou-story .rte > *:first-child {
    margin-top: 0;
  }

  .ocaou-story .rte > *:last-child {
    margin-bottom: 0;
  }

  .ocaou-story .rte strong {
    color: var(--ocaou-accent);
    font-weight: 800;
  }

  @media screen and (max-width: 749px) {
    .ocaou-story {
      padding: var(--ocaou-space-top-mobile) 16px var(--ocaou-space-bottom-mobile);
    }

    .ocaou-story__title {
      font-size: var(--ocaou-title-size-mobile);
    }

    .ocaou-story__intro {
      margin-top: 26px;
    }

    .ocaou-story__chips {
      margin-top: 16px;
      margin-bottom: 28px;
      gap: max(10px, calc(var(--ocaou-chip-gap) - 4px));
    }

    .ocaou-story--mobile-1 .ocaou-story__chip {
      flex-basis: 100%;
      max-width: 430px;
    }

    .ocaou-story--mobile-2 .ocaou-story__chip:not(.ocaou-story__chip--full) {
      flex-basis: calc(50% - (var(--ocaou-chip-gap) / 2));
    }

    .ocaou-story__chip {
      min-height: 48px;
      padding: 11px 14px;
      transform: none;
    }

    .ocaou-story__challenge {
      margin-top: 26px;
    }

    .ocaou-story__body {
      margin-top: 22px;
    }
  }
</style>

{% schema %}
{
  "name": "Notre histoire O'CAOU",
  "tag": "section",
  "class": "section-ocaou-story",
  "max_blocks": 20,
  "settings": [
    {
      "type": "header",
      "content": "Contenu principal"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Petit titre",
      "default": "NOTRE HISTOIRE"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Pourquoi O'CAOU ?"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Balise du titre",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ]
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "Parce qu'on le dit 10 fois par jour !"
    },
    {
      "type": "richtext",
      "id": "intro_text",
      "label": "Texte avant les étiquettes",
      "default": "<p>Parce qu'être parent, c'est penser à tout :</p>"
    },
    {
      "type": "richtext",
      "id": "transition_text",
      "label": "Texte après les étiquettes",
      "default": "<p>Parce qu'on veut du bien à nos enfants, qu'ils soient bien.<br>Être parent, c'est beaucoup : ranger, anticiper, s'organiser.</p>"
    },
    {
      "type": "text",
      "id": "challenge_prefix",
      "label": "Phrase forte — début",
      "default": "Le plus grand défi ?"
    },
    {
      "type": "text",
      "id": "challenge_highlight",
      "label": "Phrase forte — partie colorée",
      "default": "NE RIEN OUBLIER !"
    },
    {
      "type": "richtext",
      "id": "main_text",
      "label": "Premier paragraphe",
      "default": "<p>Alors <strong>O'CAOU prévoit, pour vous et vos petits.</strong> O'CAOU imagine des essentiels pratiques et ludiques qui accompagnent les familles de la maternité à la maternelle. Des accessoires pour être parés à toutes les éventualités : avec O'CAOU, vous aurez des solutions pour tous les imprévus du quotidien.</p>"
    },
    {
      "type": "richtext",
      "id": "final_text",
      "label": "Dernier paragraphe",
      "default": "<p>Des étiquettes partout pour guider, pour vous soulager. Les petits gagnent en autonomie : <strong>ils lisent en rangeant</strong> et préparent leurs affaires tout seuls, comme des grands.</p>"
    },
    {
      "type": "header",
      "content": "Mise en page"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Alignement du texte",
      "default": "center",
      "options": [
        { "value": "center", "label": "Centré" },
        { "value": "left", "label": "À gauche" }
      ]
    },
    {
      "type": "range",
      "id": "content_width",
      "min": 600,
      "max": 1200,
      "step": 20,
      "unit": "px",
      "label": "Largeur maximale du contenu",
      "default": 900
    },
    {
      "type": "range",
      "id": "chips_width",
      "min": 500,
      "max": 1100,
      "step": 20,
      "unit": "px",
      "label": "Largeur de la zone des étiquettes",
      "default": 760
    },
    {
      "type": "select",
      "id": "mobile_chip_columns",
      "label": "Étiquettes sur mobile",
      "default": "1",
      "options": [
        { "value": "1", "label": "1 colonne" },
        { "value": "2", "label": "2 colonnes" }
      ]
    },
    {
      "type": "range",
      "id": "chip_gap",
      "min": 8,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Espace entre les étiquettes",
      "default": 14
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Arrière-plan",
      "default": "#FBF7EE"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Texte courant",
      "default": "#2D2926"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Titres",
      "default": "#2D2926"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Couleur d'accent",
      "default": "#D75B45"
    },
    {
      "type": "header",
      "content": "Tailles de texte"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 28,
      "max": 72,
      "step": 2,
      "unit": "px",
      "label": "Titre — ordinateur",
      "default": 38
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "min": 24,
      "max": 48,
      "step": 1,
      "unit": "px",
      "label": "Titre — mobile",
      "default": 30
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "min": 16,
      "max": 34,
      "step": 1,
      "unit": "px",
      "label": "Sous-titre",
      "default": 22
    },
    {
      "type": "range",
      "id": "body_size",
      "min": 14,
      "max": 22,
      "step": 1,
      "unit": "px",
      "label": "Texte courant",
      "default": 17
    },
    {
      "type": "header",
      "content": "Espacement"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Marge haute — ordinateur",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Marge basse — ordinateur",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 16,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Marge haute — mobile",
      "default": 44
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 16,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Marge basse — mobile",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "message",
      "name": "Étiquette colorée",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Texte",
          "default": "Au cas où…"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icône ou emoji",
          "default": "✨"
        },
        {
          "type": "select",
          "id": "icon_position",
          "label": "Position de l'icône",
          "default": "right",
          "options": [
            { "value": "left", "label": "À gauche" },
            { "value": "right", "label": "À droite" }
          ]
        },
        {
          "type": "color",
          "id": "background_color",
          "label": "Couleur de fond",
          "default": "#F7DDD5"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Couleur du texte",
          "default": "#2D2926"
        },
        {
          "type": "select",
          "id": "desktop_width",
          "label": "Largeur sur ordinateur",
          "default": "medium",
          "options": [
            { "value": "compact", "label": "Compacte" },
            { "value": "medium", "label": "Moyenne" },
            { "value": "large", "label": "Large" },
            { "value": "full", "label": "Pleine largeur" }
          ]
        },
        {
          "type": "range",
          "id": "font_size",
          "min": 12,
          "max": 22,
          "step": 1,
          "unit": "px",
          "label": "Taille du texte",
          "default": 15
        },
        {
          "type": "range",
          "id": "border_radius",
          "min": 0,
          "max": 40,
          "step": 2,
          "unit": "px",
          "label": "Arrondi",
          "default": 28
        },
        {
          "type": "range",
          "id": "rotation",
          "min": -3,
          "max": 3,
          "step": 1,
          "unit": "deg",
          "label": "Inclinaison",
          "default": 0
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Notre histoire O'CAOU",
      "blocks": [
        {
          "type": "message",
          "settings": {
            "text": "Au cas où il a soif",
            "icon": "🥤",
            "background_color": "#F7DDD5",
            "desktop_width": "medium",
            "rotation": -1
          }
        },
        {
          "type": "message",
          "settings": {
            "text": "Au cas où il a faim",
            "icon": "🍎",
            "background_color": "#FAEDC4",
            "desktop_width": "medium",
            "rotation": 1
          }
        },
        {
          "type": "message",
          "settings": {
            "text": "Au cas où il a froid",
            "icon": "🧣",
            "background_color": "#CFE7EC",
            "desktop_width": "medium",
            "rotation": -1
          }
        },
        {
          "type": "message",
          "settings": {
            "text": "Au cas où il a peur",
            "icon": "💡",
            "background_color": "#FBE9C9",
            "desktop_width": "medium",
            "rotation": 1
          }
        },
        {
          "type": "message",
          "settings": {
            "text": "Au cas où c'est chaud",
            "icon": "🔥",
            "background_color": "#F6DAD5",
            "desktop_width": "medium",
            "rotation": -1
          }
        },
        {
          "type": "message",
          "settings": {
            "text": "Au cas où c'est froid",
            "icon": "❄️",
            "background_color": "#D9EFEB",
            "desktop_width": "medium",
            "rotation": 1
          }
        },
        {
          "type": "message",
          "settings": {
            "text": "Au cas où ça coule",
            "icon": "💧",
            "background_color": "#F1DDD8",
            "desktop_width": "medium",
            "rotation": -1
          }
        }
      ]
    }
  ]
}
{% endschema %}