{% style %}
  #shopify-section-{{ section.id }} .fp-benefits-section {
    width: 100%;
    background: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .fp-benefits-container {
    max-width: {% if section.settings.full_width %}none{% else %}{{ section.settings.max_width }}px{% endif %};
    margin: 0 auto;
    padding-left: {{ section.settings.side_padding_desktop }}px;
    padding-right: {{ section.settings.side_padding_desktop }}px;
  }

  #shopify-section-{{ section.id }} .fp-benefits-title {
    margin: 0 0 {{ section.settings.title_margin_bottom_desktop }}px;
    text-align: {{ section.settings.title_alignment }};
    color: {{ section.settings.title_color }};
    font-size: {{ section.settings.title_size_desktop }}px;
    font-weight: {{ section.settings.title_weight }};
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .fp-benefits-grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, 1fr));
    gap: {{ section.settings.row_gap_desktop }}px {{ section.settings.column_gap_desktop }}px;
    align-items: start;
  }

  #shopify-section-{{ section.id }} .fp-benefit-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .fp-benefit-icon-circle {
    width: {{ section.settings.icon_circle_size_desktop }}px;
    height: {{ section.settings.icon_circle_size_desktop }}px;
    border-radius: 999px;
    background: {{ section.settings.icon_circle_bg }};
    color: {{ section.settings.icon_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: {{ section.settings.icon_margin_bottom_desktop }}px;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .fp-benefit-icon-circle svg {
    width: {{ section.settings.icon_size_desktop }}px;
    height: {{ section.settings.icon_size_desktop }}px;
    display: block;
    stroke: currentColor;
  }

  #shopify-section-{{ section.id }} .fp-benefit-icon-circle img {
    width: {{ section.settings.icon_size_desktop }}px;
    height: {{ section.settings.icon_size_desktop }}px;
    object-fit: contain;
    display: block;
  }

  #shopify-section-{{ section.id }} .fp-benefit-title {
    margin: 0 0 {{ section.settings.benefit_title_margin_bottom }}px;
    color: {{ section.settings.benefit_title_color }};
    font-size: {{ section.settings.benefit_title_size_desktop }}px;
    font-weight: {{ section.settings.benefit_title_weight }};
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .fp-benefit-text {
    margin: 0;
    max-width: {{ section.settings.text_max_width_desktop }}px;
    color: {{ section.settings.text_color }};
    font-size: {{ section.settings.text_size_desktop }}px;
    font-weight: {{ section.settings.text_weight }};
    line-height: 1.35;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .fp-benefits-section {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }

    #shopify-section-{{ section.id }} .fp-benefits-container {
      padding-left: {{ section.settings.side_padding_mobile }}px;
      padding-right: {{ section.settings.side_padding_mobile }}px;
    }

    #shopify-section-{{ section.id }} .fp-benefits-title {
      margin-bottom: {{ section.settings.title_margin_bottom_mobile }}px;
      font-size: {{ section.settings.title_size_mobile }}px;
    }

    #shopify-section-{{ section.id }} .fp-benefits-grid {
      grid-template-columns: repeat({{ section.settings.columns_mobile }}, minmax(0, 1fr));
      gap: {{ section.settings.row_gap_mobile }}px {{ section.settings.column_gap_mobile }}px;
    }

    #shopify-section-{{ section.id }} .fp-benefit-icon-circle {
      width: {{ section.settings.icon_circle_size_mobile }}px;
      height: {{ section.settings.icon_circle_size_mobile }}px;
      margin-bottom: {{ section.settings.icon_margin_bottom_mobile }}px;
    }

    #shopify-section-{{ section.id }} .fp-benefit-icon-circle svg,
    #shopify-section-{{ section.id }} .fp-benefit-icon-circle img {
      width: {{ section.settings.icon_size_mobile }}px;
      height: {{ section.settings.icon_size_mobile }}px;
    }

    #shopify-section-{{ section.id }} .fp-benefit-title {
      font-size: {{ section.settings.benefit_title_size_mobile }}px;
      margin-bottom: {{ section.settings.benefit_title_margin_bottom_mobile }}px;
    }

    #shopify-section-{{ section.id }} .fp-benefit-text {
      max-width: {{ section.settings.text_max_width_mobile }}px;
      font-size: {{ section.settings.text_size_mobile }}px;
      line-height: 1.35;
    }
  }
{% endstyle %}

<section class="fp-benefits-section">
  <div class="fp-benefits-container">

    {% if section.settings.title != blank %}
      <h2 class="fp-benefits-title">
        {{ section.settings.title }}
      </h2>
    {% endif %}

    <div class="fp-benefits-grid">
      {% for block in section.blocks %}
        <div class="fp-benefit-item" {{ block.shopify_attributes }}>

          <div class="fp-benefit-icon-circle">
            {% if block.settings.custom_icon != blank %}
              <img
                src="{{ block.settings.custom_icon | image_url: width: 300 }}"
                alt="{{ block.settings.icon_alt | escape }}"
                loading="lazy"
                width="300"
                height="300"
              >
            {% else %}
              {% case block.settings.icon %}
                {% when 'smile' %}
                  <svg viewBox="0 0 64 64" fill="none" aria-hidden="true">
                    <circle cx="32" cy="32" r="22" stroke-width="4"/>
                    <path d="M23 26H23.1" stroke-width="5" stroke-linecap="round"/>
                    <path d="M41 26H41.1" stroke-width="5" stroke-linecap="round"/>
                    <path d="M22 36C25 43 39 43 42 36" stroke-width="4" stroke-linecap="round"/>
                  </svg>

                {% when 'wash' %}
                  <svg viewBox="0 0 64 64" fill="none" aria-hidden="true">
                    <path d="M32 8C23 20 18 28 18 38C18 47 24 54 32 54C40 54 46 47 46 38C46 28 41 20 32 8Z" stroke-width="4" stroke-linejoin="round"/>
                    <circle cx="43" cy="43" r="10" stroke-width="3"/>
                    <path d="M38.5 43L42 46.5L48 39.5" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>

                {% when 'clock' %}
                  <svg viewBox="0 0 64 64" fill="none" aria-hidden="true">
                    <path d="M32 10C20 10 10 20 10 32C10 44 20 54 32 54" stroke-width="4" stroke-linecap="round"/>
                    <path d="M32 18V33L42 39" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M51 23C54 28 55 35 53 41" stroke-width="4" stroke-linecap="round" stroke-dasharray="2 7"/>
                  </svg>

                {% when 'truck' %}
                  <svg viewBox="0 0 64 64" fill="none" aria-hidden="true">
                    <path d="M10 24H36V45H10V24Z" stroke-width="4" stroke-linejoin="round"/>
                    <path d="M36 31H47L56 39V45H36V31Z" stroke-width="4" stroke-linejoin="round"/>
                    <circle cx="21" cy="47" r="5" stroke-width="4"/>
                    <circle cx="47" cy="47" r="5" stroke-width="4"/>
                    <path d="M5 32H18" stroke-width="4" stroke-linecap="round"/>
                    <path d="M8 39H22" stroke-width="4" stroke-linecap="round"/>
                  </svg>

                {% when 'bag' %}
                  <svg viewBox="0 0 64 64" fill="none" aria-hidden="true">
                    <path d="M20 25V19C20 12.9 24.9 8 31 8H33C39.1 8 44 12.9 44 19V25" stroke-width="4" stroke-linecap="round"/>
                    <path d="M14 25H50L47 56H17L14 25Z" stroke-width="4" stroke-linejoin="round"/>
                    <path d="M24 37H40" stroke-width="4" stroke-linecap="round"/>
                    <path d="M32 29V45" stroke-width="4" stroke-linecap="round"/>
                  </svg>

                {% else %}
                  <svg viewBox="0 0 64 64" fill="none" aria-hidden="true">
                    <circle cx="32" cy="32" r="22" stroke-width="4"/>
                    <path d="M22 33L29 40L43 24" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
              {% endcase %}
            {% endif %}
          </div>

          {% if block.settings.title != blank %}
            <h3 class="fp-benefit-title">
              {{ block.settings.title }}
            </h3>
          {% endif %}

          {% if block.settings.text != blank %}
            <p class="fp-benefit-text">
              {{ block.settings.text }}
            </p>
          {% endif %}

        </div>
      {% endfor %}
    </div>

  </div>
</section>

{% schema %}
